<section class="row-section">
  <h2 class="row-heading">
    <% if (locals.href) { %>
      <a href="<%= href %>" class="row-link"><%= label %> <span class="row-explore">Explore All ›</span></a>
    <% } else { %>
      <%= label %>
    <% } %>
  </h2>
  <div class="slider-wrap" data-row="<%= rowId %>">
    <button class="slider-btn prev" onclick="slide('<%= rowId %>', -1)" aria-label="Previous">&#8249;</button>
    <div class="slider-track" id="track-<%= rowId %>">
      <% movies.forEach(movie => { %>
        <%- include('./card', { movie }) %>

      <% }) %>
    </div>
    <button class="slider-btn next" onclick="slide('<%= rowId %>', 1)" aria-label="Next">&#8250;</button>
  </div>
</section>
